# Base de datos
DATABASE_URL=postgresql://receiptile:receiptile@localhost:5432/receiptile_dev

# Puerto del servidor
PORT=3001

# URL del frontend (para CORS)
WEB_URL=http://localhost:3000

# JWT — cambiá esto por un string largo y random en producción
# Para generar uno: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production

# Tiempo de ventana para mostrar el ticket más reciente (en minutos)
TICKET_WINDOW_MINUTES=5
